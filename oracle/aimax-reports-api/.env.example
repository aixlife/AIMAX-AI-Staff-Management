AIMAX_REPORT_HOST=127.0.0.1
AIMAX_REPORT_PORT=18988
AIMAX_REPORT_DATA_DIR=/home/ubuntu/aimax-reports/data
AIMAX_REPORT_MAX_BODY_BYTES=3145728
AIMAX_REPORT_TOKEN=change-this-long-random-token
AIMAX_ADMIN_TOKEN=change-this-different-long-random-token
AIMAX_ALLOWED_ORIGINS=https://aimax.ai.kr,http://localhost:3000,http://127.0.0.1:3000
AIMAX_SESSION_TTL_DAYS=30
AIMAX_AGENT_JOB_CLAIM_TTL_SECONDS=86400
AIMAX_LATEST_AGENT_VERSION=v1.0.51
AIMAX_MIN_AGENT_VERSION=v1.0.44
AIMAX_WINDOWS_LATEST_AGENT_VERSION=v1.0.51
AIMAX_WINDOWS_MIN_AGENT_VERSION=v1.0.44
AIMAX_MACOS_LATEST_AGENT_VERSION=v1.0.51
AIMAX_MACOS_MIN_AGENT_VERSION=v1.0.36
AIMAX_AGENT_DOWNLOAD_URL=
AIMAX_AGENT_RELEASE_NOTES=AIMAX 실행기 업데이트를 확인해주세요.
AIMAX_DOWNLOAD_DIR=/home/ubuntu/aimax-downloads
AIMAX_MAIL_FROM=AIMAX <naminsoo@aixlife.co.kr>
AIMAX_MAIL_REPLY_TO=naminsoo@aixlife.co.kr
# Gmail 발송은 Google Apps Script Web App URL을 권장합니다.
AIMAX_MAIL_WEBHOOK_URL=
AIMAX_MAIL_WEBHOOK_SECRET=change-this-mail-webhook-secret
# Resend HTTP API를 쓸 때만 설정합니다.
AIMAX_RESEND_API_KEY=
