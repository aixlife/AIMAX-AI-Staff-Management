diff --git a/b/scripts/v107_diagnostics_smoke.py b/scripts/v107_diagnostics_smoke.py
new file mode 100644
index 0000000..e8a1361
--- /dev/null
+++ b/scripts/v107_diagnostics_smoke.py
@@ -0,0 +1,216 @@
+"""v1.0.7 diagnostic smoke tests.
+
+This script stubs provider SDK/network calls. It does not call paid AI APIs,
+does not open a browser, and does not publish to Naver.
+"""
+from __future__ import annotations
+
+import json
+import os
+import sys
+import types
+from typing import Any
+
+ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
+if ROOT not in sys.path:
+    sys.path.insert(0, ROOT)
+os.environ["APPDATA"] = os.path.join(ROOT, ".tmp", "v107-diagnostics-smoke-appdata")
+
+
+class FakeResponse:
+    def __init__(self, status_code: int, body: dict[str, Any], headers: dict[str, str] | None = None) -> None:
+        self.status_code = status_code
+        self._body = body
+        self.headers = headers or {}
+        self.text = json.dumps(body, ensure_ascii=False)
+
+    def json(self) -> dict[str, Any]:
+        return self._body
+
+
+def _expect(condition: bool, message: str) -> None:
+    if not condition:
+        raise AssertionError(message)
+
+
+def run_openai_cases(results: list[dict[str, Any]]) -> None:
+    import requests
+    from content.ai_text import AiGenerationError, AiQuotaError, generate_blog_content
+
+    original_post = requests.post
+
+    def run_case(name: str, fake_response: FakeResponse, expected_cls: type[Exception], expected_status: int) -> None:
+        def fake_post(*_args: Any, **_kwargs: Any) -> FakeResponse:
+            return fake_response
+
+        requests.post = fake_post
+        try:
+            generate_blog_content("진단키워드", "sk-test-redacted", model="gpt-5.4-mini", return_usage=True)
+            raise AssertionError(f"{name}: expected provider error")
+        except expected_cls as error:
+            detail = error.to_dict()
+            _expect(detail.get("provider") == "openai", f"{name}: provider missing {detail}")
+            _expect(detail.get("model") == "gpt-5.4-mini", f"{name}: model missing {detail}")
+            _expect(detail.get("http_status") == expected_status, f"{name}: http status missing {detail}")
+            results.append({"case": name, "passed": True, "detail": detail})
+        finally:
+            requests.post = original_post
+
+    run_case(
+        "openai_http_400_invalid_model",
+        FakeResponse(
+            400,
+            {"error": {"message": "Invalid model: gpt-test", "type": "invalid_request_error", "code": "model_not_found"}},
+            {"x-request-id": "req-openai-400"},
+        ),
+        AiGenerationError,
+        400,
+    )
+    run_case(
+        "openai_http_429_quota",
+        FakeResponse(
+            429,
+            {"error": {"message": "Quota exceeded", "type": "rate_limit_error", "code": "insufficient_quota"}},
+            {"x-request-id": "req-openai-429"},
+        ),
+        AiQuotaError,
+        429,
+    )
+
+    def fake_empty_post(*_args: Any, **_kwargs: Any) -> FakeResponse:
+        return FakeResponse(
+            200,
+            {
+                "id": "resp-empty",
+                "output": [],
+                "usage": {"input_tokens": 11, "output_tokens": 0, "total_tokens": 11},
+            },
+            {"x-request-id": "req-openai-empty"},
+        )
+
+    requests.post = fake_empty_post
+    try:
+        generate_blog_content("빈응답", "sk-test-redacted", model="gpt-5.4-mini", return_usage=True)
+        raise AssertionError("openai_empty_output: expected provider error")
+    except AiGenerationError as error:
+        detail = error.to_dict()
+        _expect(detail.get("code") == "empty_output", f"openai empty code missing {detail}")
+        _expect(detail.get("usage", {}).get("input_tokens") == 11, f"openai empty usage missing {detail}")
+        results.append({"case": "openai_empty_output", "passed": True, "detail": detail})
+    finally:
+        requests.post = original_post
+
+
+def run_gemini_case(results: list[dict[str, Any]]) -> None:
+    from content.ai_text import AiQuotaError, generate_blog_content
+
+    old_google = sys.modules.get("google")
+
+    class FakeModels:
+        def generate_content(self, *_args: Any, **_kwargs: Any) -> None:
+            raise RuntimeError("RESOURCE_EXHAUSTED 429 quota limit: 0")
+
+    class FakeClient:
+        def __init__(self, *_args: Any, **_kwargs: Any) -> None:
+            self.models = FakeModels()
+
+    fake_google = types.ModuleType("google")
+    fake_google.genai = types.SimpleNamespace(Client=FakeClient)
+    sys.modules["google"] = fake_google
+    try:
+        generate_blog_content("Gemini진단", "gemini-test-redacted", model="gemini-2.5-pro", return_usage=True)
+        raise AssertionError("gemini_exception_path: expected provider error")
+    except AiQuotaError as error:
+        detail = error.to_dict()
+        _expect(detail.get("provider") == "gemini", f"gemini provider missing {detail}")
+        _expect(detail.get("model") == "gemini-2.5-pro", f"gemini model missing {detail}")
+        results.append({"case": "gemini_exception_path", "passed": True, "detail": detail})
+    finally:
+        if old_google is None:
+            sys.modules.pop("google", None)
+        else:
+            sys.modules["google"] = old_google
+
+
+def run_claude_case(results: list[dict[str, Any]]) -> None:
+    from content.ai_text import AiGenerationError, generate_blog_content
+
+    old_anthropic = sys.modules.get("anthropic")
+
+    class FakeClaudeError(RuntimeError):
+        status_code = 500
+        request_id = "req-claude-500"
+        body = {"error": {"message": "Claude upstream unavailable", "type": "api_error", "code": "server_error"}}
+
+    class FakeMessages:
+        def create(self, *_args: Any, **_kwargs: Any) -> None:
+            raise FakeClaudeError("Claude upstream unavailable")
+
+    class FakeAnthropicClient:
+        def __init__(self, *_args: Any, **_kwargs: Any) -> None:
+            self.messages = FakeMessages()
+
+    fake_anthropic = types.ModuleType("anthropic")
+    fake_anthropic.Anthropic = FakeAnthropicClient
+    sys.modules["anthropic"] = fake_anthropic
+    try:
+        generate_blog_content("Claude진단", "claude-test-redacted", model="claude", return_usage=True)
+        raise AssertionError("claude_exception_path: expected provider error")
+    except AiGenerationError as error:
+        detail = error.to_dict()
+        _expect(detail.get("provider") == "claude", f"claude provider missing {detail}")
+        _expect(detail.get("request_id") == "req-claude-500", f"claude request id missing {detail}")
+        results.append({"case": "claude_exception_path", "passed": True, "detail": detail})
+    finally:
+        if old_anthropic is None:
+            sys.modules.pop("anthropic", None)
+        else:
+            sys.modules["anthropic"] = old_anthropic
+
+
+def run_local_timeout_case(results: list[dict[str, Any]]) -> None:
+    from app import _build_write_result, _format_local_executor_timeout, _local_executor_timeout_detail
+
+    error = RuntimeError("HTTPConnectionPool(host='localhost', port=8669): Read timed out. (read timeout=120)")
+    detail = _local_executor_timeout_detail(error, "naver_login")
+    _expect(detail is not None, "local timeout detail missing")
+    message = _format_local_executor_timeout(error, "naver_login")
+    result = _build_write_result(
+        False,
+        0,
+        1,
+        "publish",
+        "gemini-2.5-pro",
+        {},
+        {},
+        posts=[],
+        failed_posts=[{
+            "source": "timeout-keyword",
+            "keyword": "timeout-keyword",
+            "type": "keyword",
+            "status": "failed",
+            "stage": "naver_login",
+            "error": message,
+            "local_executor": detail,
+        }],
+        error=message,
+        stage="naver_login",
+        failed_keyword="timeout-keyword",
+    )
+    _expect(result.get("local_executor", {}).get("endpoint") == "localhost:8669", f"local result missing {result}")
+    _expect(result.get("status") is None and result.get("ok") is False, f"local result ok/status invalid {result}")
+    results.append({"case": "localhost_8669_timeout_result", "passed": True, "detail": result.get("local_executor")})
+
+
+def main() -> int:
+    results: list[dict[str, Any]] = []
+    run_openai_cases(results)
+    run_gemini_case(results)
+    run_claude_case(results)
+    run_local_timeout_case(results)
+    print(json.dumps({"ok": True, "paid_api_or_publish_calls": "not_run", "cases": results}, ensure_ascii=False, indent=2))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
