 class AiGenerationError(RuntimeError):
     """사용자에게 그대로 보여줄 수 있는 AI 생성 오류."""
 
     fatal = False
 
+    def __init__(
+        self,
+        message,
+        *,
+        provider="",
+        model="",
+        http_status=None,
+        error_type="",
+        error_code="",
+        request_id="",
+        response_id="",
+        usage=None,
+        hard_stop=False,
+    ):
+        safe_message = _safe_message(message)
+        super().__init__(safe_message)
+        self.provider = str(provider or "")
+        self.model = str(model or "")
+        self.http_status = _safe_int(http_status)
+        self.error_type = _safe_message(error_type, limit=120)
+        self.error_code = _safe_message(error_code, limit=120)
+        self.request_id = _safe_message(request_id, limit=160)
+        self.response_id = _safe_message(response_id, limit=160)
+        self.usage = _normalize_usage_dict(usage)
+        self.hard_stop = bool(hard_stop)
+        self.message = safe_message
+
+    def to_dict(self):
+        detail = {
+            "provider": self.provider,
+            "model": self.model,
+            "message": self.message,
+            "fatal": bool(getattr(self, "fatal", False)),
+            "hard_stop": bool(getattr(self, "hard_stop", False)),
+        }
+        if self.http_status is not None:
+            detail["http_status"] = self.http_status
+        if self.error_type:
+            detail["type"] = self.error_type
+        if self.error_code:
+            detail["code"] = self.error_code
+        if self.request_id:
+            detail["request_id"] = self.request_id
+        if self.response_id:
+            detail["response_id"] = self.response_id
+        if self.usage:
+            detail["usage"] = self.usage
+        return detail
+
 
 class AiQuotaError(AiGenerationError):
     """API 사용량/요금제 문제처럼 남은 작업도 실패할 가능성이 높은 오류."""
 
     fatal = True
 
-    def __init__(self, message, retry_after=None, hard_stop=True):
-        super().__init__(message)
+    def __init__(self, message, retry_after=None, hard_stop=True, **kwargs):
+        super().__init__(message, hard_stop=hard_stop, **kwargs)
         self.retry_after = retry_after
         self.hard_stop = hard_stop
 
+    def to_dict(self):
+        detail = super().to_dict()
+        if self.retry_after:
+            detail["retry_after"] = self.retry_after
+        return detail
+
+
+def _safe_int(value):
+    try:
+        if value is None or value == "":
+            return None
+        return int(value)
+    except (TypeError, ValueError):
+        return None
+
+
+def _safe_message(value, limit=500):
+    text = mask_text(value)
+    text = re.sub(r"\s+", " ", text or "").strip()
+    return text[:limit]
+
+
+def _normalize_usage_dict(usage):
+    if not isinstance(usage, dict):
+        return {}
+    normalized = {}
+    for key in ("input_tokens", "output_tokens", "thinking_tokens", "billable_output_tokens", "total_tokens"):
+        try:
+            value = int(usage.get(key) or 0)
+        except (TypeError, ValueError):
+            value = 0
+        if value:
+            normalized[key] = value
+    return normalized
+
+
+def _request_id_from_response(response):
+    headers = getattr(response, "headers", {}) or {}
+    for key in ("x-request-id", "openai-request-id", "request-id", "x-correlation-id"):
+        value = headers.get(key)
+        if value:
+            return value
+    return ""
+
+
+def _parse_json_response(response):
+    try:
+        return response.json()
+    except Exception:
+        try:
+            return json.loads(getattr(response, "text", "") or "{}")
+        except Exception:
+            return {}
+
+
+def _openai_error_details(response):
+    data = _parse_json_response(response)
+    err = data.get("error") if isinstance(data, dict) else {}
+    if isinstance(err, dict):
+        message = err.get("message") or data.get("message") or getattr(response, "text", "")
+        error_type = err.get("type") or data.get("type") or ""
+        error_code = err.get("code") or data.get("code") or ""
+    else:
+        message = err or data.get("message") if isinstance(data, dict) else getattr(response, "text", "")
+        error_type = data.get("type") if isinstance(data, dict) else ""
+        error_code = data.get("code") if isinstance(data, dict) else ""
+    return {
+        "message": _safe_message(message or f"HTTP {getattr(response, 'status_code', '')}"),
+        "type": _safe_message(error_type, limit=120),
+        "code": _safe_message(error_code, limit=120),
+        "request_id": _request_id_from_response(response),
+        "usage": _openai_usage(data),
+    }
+
+
+def _openai_usage(data):
+    if not isinstance(data, dict):
+        return {}
+    usage_data = data.get("usage") or {}
+    if not isinstance(usage_data, dict):
+        return {}
+    output_details = usage_data.get("output_tokens_details") or {}
+    usage = {
+        "input_tokens": usage_data.get("input_tokens") or 0,
+        "output_tokens": usage_data.get("output_tokens") or 0,
+        "thinking_tokens": output_details.get("reasoning_tokens") or 0,
+        "billable_output_tokens": usage_data.get("output_tokens") or 0,
+        "total_tokens": usage_data.get("total_tokens") or 0,
+    }
+    return _normalize_usage_dict(usage)
+
+
+def _exception_diagnostics(provider, model_id, error):
+    response = getattr(error, "response", None)
+    body = getattr(error, "body", None)
+    status = getattr(error, "status_code", None) or getattr(response, "status_code", None)
+    request_id = getattr(error, "request_id", "") or _request_id_from_response(response)
+    error_type = getattr(error, "type", "") or ""
+    error_code = getattr(error, "code", "") or ""
+    message = getattr(error, "message", "") or str(error)
+    if isinstance(body, dict):
+        err = body.get("error") if isinstance(body.get("error"), dict) else body
+        message = err.get("message") or message
+        error_type = err.get("type") or error_type
+        error_code = err.get("code") or error_code
+    return {
+        "provider": provider,
+        "model": model_id,
+        "http_status": status,
+        "error_type": error_type,
+        "error_code": error_code,
+        "request_id": request_id,
+        "message": message,
+    }
+
+
+def _is_quota_or_rate_limit(status, message="", error_type="", error_code=""):
+    text = " ".join(str(item or "") for item in (message, error_type, error_code)).lower()
+    return (
+        _safe_int(status) == 429
+        or "quota" in text
+        or "rate_limit" in text
+        or "rate limit" in text
+        or "resource_exhausted" in text
+        or "insufficient_quota" in text
+    )
+
+
+def _provider_error_from_exception(provider, model_id, error):
+    details = _exception_diagnostics(provider, model_id, error)
+    message = _safe_message(details.pop("message", "") or error)
+    cls = AiQuotaError if _is_quota_or_rate_limit(
+        details.get("http_status"),
+        message,
+        details.get("error_type"),
+        details.get("error_code"),
+    ) else AiGenerationError
+    return cls(message, **details)
+
 
