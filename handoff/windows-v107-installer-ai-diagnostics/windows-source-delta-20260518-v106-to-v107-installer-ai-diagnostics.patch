+function IsProcessRunning(ImageName: String): Boolean;
+var
+  ResultCode: Integer;
+begin
+  Result := False;
+  if not Exec(
+    ExpandConstant('{cmd}'),
+    '/C tasklist /FI "IMAGENAME eq ' + ImageName + '" /NH | find /I "' + ImageName + '" >NUL',
+    '',
+    SW_HIDE,
+    ewWaitUntilTerminated,
+    ResultCode
+  ) then begin
+    Exit;
+  end;
+  Result := ResultCode = 0;
+end;
+
+function CloseAimaxProcess(ImageName: String): Boolean;
+var
+  ResultCode: Integer;
+  WaitIndex: Integer;
+begin
+  Result := True;
+  if not IsProcessRunning(ImageName) then begin
+    Exit;
+  end;
+
+  Exec(
+    ExpandConstant('{sys}\taskkill.exe'),
+    '/IM "' + ImageName + '" /T',
+    '',
+    SW_HIDE,
+    ewWaitUntilTerminated,
+    ResultCode
+  );
+
+  for WaitIndex := 1 to 20 do begin
+    if not IsProcessRunning(ImageName) then begin
+      Exit;
+    end;
+    Sleep(500);
+  end;
+
+  Result := not IsProcessRunning(ImageName);
+end;
+
