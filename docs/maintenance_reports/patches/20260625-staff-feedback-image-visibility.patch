+    system: {
+      jobs_recent: [
+        {
+          id: "latest-done-image-job",
+          kind: "yeri_write",
+          worker_code: "yeri_writer",
+          status: "done",
+          result: { images: { attempted: 1, generated: 1, inserted: 1, failure_count: 0 } },
