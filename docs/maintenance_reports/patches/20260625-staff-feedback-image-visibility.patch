+          failed_stage: "naver_login",
+        },
+      ],
+    },
+    support: { status: "reviewing", updated_at: storedAt },
+  };
+  const feedbackTicket = __automationTest.buildAutomationTicketForReport(feedbackReport, storedAt, storedAt.slice(0, 10));
+  assert(feedbackTicket.category === "staff_feedback", "feedback_ticket_category_mismatch");
+  assert(feedbackTicket.job_id === "latest-done-image-job", "feedback_should_use_latest_job");
+  assert(feedbackTicket.job_status === "done", "feedback_latest_job_status_mismatch");
   console.log("AUTOMATION_TICKETS_SMOKE_OK");
 } finally {
   fs.rmSync(tmpRoot, { recursive: true, force: true });
diff --git a/scripts/smoke_report_auto_guidance_completion_sync.py b/scripts/smoke_report_auto_guidance_completion_sync.py
