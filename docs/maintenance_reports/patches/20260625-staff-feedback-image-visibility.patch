+    payload = json.loads(result.stdout)
+    assert payload["touched_count"] == 1, payload
+    assert payload["touched"][0]["category"] == "staff_feedback_image_visibility_working", payload
+    rows = guidance.read_rows(data_dir / "reports-index.jsonl")
+    assert rows[0]["status"] == "working", rows[0]
+    assert guidance.latest_ticket_statuses(data_dir)[feedback_ticket_id] == "working"
