 }
 
 
@@ -339,6 +351,36 @@ def image_paid_required_saved_as_draft(job: dict[str, Any]) -> bool:
     return any(str(item.get("error_code") or item.get("error") or "") == "image_paid_required" for item in failures if isinstance(item, dict))
 
 
+def feedback_recent_job(row: dict[str, Any], detail: dict[str, Any] | None, jobs_by_id: dict[str, dict[str, Any]]) -> dict[str, Any] | None:
+    jobs = (detail or {}).get("system", {}).get("jobs_recent")
+    if isinstance(jobs, list):
+        for job in jobs:
+            if isinstance(job, dict):
+                return job
+    job_id = str(row.get("job_id") or "")
+    return jobs_by_id.get(job_id) if job_id else None
+
+
+def staff_feedback_image_visibility_guidance(
+    row: dict[str, Any],
+    detail: dict[str, Any] | None,
+    jobs_by_id: dict[str, dict[str, Any]],
+) -> Guidance | None:
+    kind = str(row.get("report_kind") or "").lower()
+    source = str(row.get("source") or "").lower()
+    if kind != "feedback" and source != "staff_feedback":
+        return None
+    if str(row.get("status") or "") != "reviewing":
+        return None
+    text = report_issue_text(row)
+    if not re.search(r"사진|이미지|image", text, re.I):
+        return None
+    job = feedback_recent_job(row, detail, jobs_by_id)
+    if job and str(job.get("status") or "") == "done" and images_completed(job):
+        return GUIDANCE["staff_feedback_image_visibility_working"]
+    return None
+
+
 def job_user_matches_report(job: dict[str, Any], row: dict[str, Any]) -> bool:
     report_user_id = str(row.get("account_user_id") or "")
     if not report_user_id:
@@ -451,7 +493,6 @@ def classify(row: dict[str, Any], detail: dict[str, Any] | None) -> Guidance | N
             return GUIDANCE[key]
 
     rules: list[tuple[str, str]] = [
-        ("browser_driver_policy_blocked", r"browser_start|브라우저 시작|chromedriver|undetected_chromedriver|애플리케이션 제어 정책|application control policy|winerror 4551"),
         ("image_paid_required", r"image_paid_reauired|image_paid_required|이미지.*유료|이미지.*사용불가|이미지 모델"),
         ("api_key_missing", r"api[_ -]?key.*missing|key_missing|no api key|no api key was provided|키가.*없|키.*저장.*필요|api.*저장.*안"),
         ("api_key_invalid", r"api_key_invalid|invalid api key|api key not valid|인증 실패|키 인증 실패|unauthorized"),
@@ -503,6 +544,7 @@ def parse_args(argv: list[str]) -> argparse.Namespace:
     parser.add_argument("--data-dir", type=Path, default=DEFAULT_DATA_DIR)
     parser.add_argument("--min-age-minutes", type=int, default=15)
     parser.add_argument("--lookback-days", type=int, default=14)
+    parser.add_argument("--report-id", default="", help="Only process one report id")
     parser.add_argument("--dry-run", action="store_true")
     return parser.parse_args(argv)
 
@@ -522,9 +564,12 @@ def main(argv: list[str]) -> int:
     synced_tickets: list[dict[str, Any]] = []
     latest_tickets = latest_ticket_statuses(data_dir)
     jobs_by_id = load_jobs_by_id(data_dir)
+    target_report_id = str(args.report_id or "").strip()
 
     backup(index_path, suffix, backups, args.dry_run)
     for row in rows:
+        if target_report_id and str(row.get("report_id") or "") != target_report_id:
+            continue
         stored_at = parse_time(str(row.get("stored_at") or ""))
         if stored_at and now - stored_at > lookback:
             continue
@@ -560,7 +605,12 @@ def main(argv: list[str]) -> int:
                 detail = json.loads(path.read_text(encoding="utf-8", errors="replace"))
             except json.JSONDecodeError:
                 detail = None
-        guidance = completion_guidance(row, detail, jobs_by_id) or still_failing_guidance(row) or classify(row, detail)
+        guidance = (
+            completion_guidance(row, detail, jobs_by_id)
+            or still_failing_guidance(row)
+            or staff_feedback_image_visibility_guidance(row, detail, jobs_by_id)
+            or classify(row, detail)
+        )
         if not guidance or not should_touch(row, guidance, min_age):
             continue
 
