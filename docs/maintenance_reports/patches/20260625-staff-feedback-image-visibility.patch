+    (report_dir / f"{stale_report_id}.json").write_text(f"{json.dumps(detail, ensure_ascii=False)}\n", encoding="utf-8")
+
+    result = subprocess.run(
+        [
+            sys.executable,
+            str(ROOT / "scripts" / "aimax_report_auto_guidance.py"),
+            "--data-dir",
+            str(data_dir),
+            "--min-age-minutes",
+            "0",
+        ],
+        check=True,
